<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Hacker Terminal - Ultimate Simulation 2026</title>
    <style>
        * { box-sizing: border-box; -webkit-user-select: none; user-select: none; margin: 0; padding: 0; }
        
        body {
            background-color: #050505;
            color: #30d158;
            font-family: 'Courier New', Courier, monospace;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
            transition: background 0.3s, color 0.3s;
        }
        
        body.light-mode { background-color: #f2f2f7; color: #1c1c1e; }
        body.light-mode .cursor { background-color: #1c1c1e; }
        body.light-mode #control-panel, body.light-mode #keyboard-container { background: #e5e5ea; border-color: #d1d1d6; }
        body.light-mode .key { background: #ffffff; color: #000000; border-color: #c7c7cc; }

        /* Màn hình hiển thị */
        #terminal-wrapper {
            width: 100%;
            height: 52vh;
            overflow-y: auto;
            padding: 12px;
            box-sizing: border-box;
        }
        #console { white-space: pre-wrap; word-wrap: break-word; font-size: 13px; font-weight: bold; line-height: 1.4; }
        .cursor { display: inline-block; width: 8px; height: 15px; background-color: #30d158; animation: blink 0.8s step-end infinite; vertical-align: middle; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

        /* Hiệu ứng ma trận đổ dọc (Matrix Rain Overlay) */
        #matrix-canvas {
            position: fixed; top: 0; left: 0; width: 100%; height: 52vh;
            pointer-events: none; opacity: 0.15; z-index: 1; display: block;
        }

        /* Các hiệu ứng thông báo */
        .overlay-box {
            display: none; position: fixed; top: 25%; left: 50%; transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.95); padding: 25px; font-weight: bold; text-align: center;
            z-index: 10000; border-radius: 8px; font-size: 16px; min-width: 280px;
        }
        #progress-box { border: 2px solid #ff9f0a; color: #ff9f0a; box-shadow: 0 0 20px rgba(255,159,10,0.4); }
        #success-box { border: 2px solid #30d158; color: #30d158; box-shadow: 0 0 20px rgba(48,209,88,0.4); }
        
        .progress-bar-bg { width: 100%; background: #222; height: 12px; border-radius: 6px; margin-top: 12px; overflow: hidden; border: 1px solid #444; }
        .progress-bar-fill { width: 0%; background: #ff9f0a; height: 100%; }
        #success-box .progress-bar-fill { background: #30d158; }

        /* Menu điều khiển */
        #control-panel {
            background: #1c1c1e; border-top: 1px solid #2c2c2e; padding: 6px;
            display: flex; flex-wrap: wrap; gap: 5px; align-items: center; justify-content: center; height: 13vh; overflow-y: auto;
        }
        select, button {
            background: #2c2c2e; color: #fff; border: 1px solid #3a3a3c; padding: 4px 8px;
            font-family: -apple-system, sans-serif; font-size: 11px; cursor: pointer; border-radius: 5px;
        }
        button:active { background: #3a3a3c; }

        /* Bảng Màu Lưới (iOS Color Picker Component) */
        #ios-color-picker {
            display: none; position: fixed; bottom: 0; left: 0; width: 100%; height: 48vh;
            background: #fff; border-top-left-radius: 12px; border-top-right-radius: 12px;
            padding: 15px; z-index: 20000; box-shadow: 0 -5px 25px rgba(0,0,0,0.3);
            font-family: -apple-system, BlinkMacSystemFont, sans-serif; color: #000;
        }
        .picker-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; font-weight: 600; }
        .close-btn { background: #e5e5ea; color: #000; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; border: none; }
        .color-grid {
            display: grid; grid-template-columns: repeat(12, 1fr); gap: 2px; background: #000; padding: 2px; border-radius: 4px;
        }
        .color-cell { aspect-ratio: 1; cursor: pointer; border: 1px solid rgba(0,0,0,0.1); }

        /* Bàn phím ảo */
        #keyboard-container {
            width: 100%; height: 35vh; background: #121212; border-top: 1px solid #2c2c2e; padding: 4px;
            display: flex; flex-direction: column; gap: 3px; justify-content: space-between;
        }
        .key-row { display: flex; gap: 3px; width: 100%; height: calc(20% - 3px); }
        .key {
            background: #1c1c1e; border: 1px solid #2c2c2e; border-radius: 5px;
            color: #d1d1d6; display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; flex: 1; min-width: 0; height: 100%;
        }
        .key:active { background: #3a3a3c; }
        
        .f-red { color: #ff453a !important; border-color: #ff453a !important; }
        .f-orange { color: #ff9f0a !important; border-color: #ff9f0a !important; }
        .f-yellow { color: #ffd60a !important; border-color: #ffd60a !important; }
        .f-green { color: #30d158 !important; border-color: #30d158 !important; }
        .f-purple { color: #bf5af2 !important; border-color: #bf5af2 !important; }
        .f-blue { color: #0a84ff !important; border-color: #0a84ff !important; }
    </style>
</head>
<body>

    <div id="terminal-wrapper">
        <canvas id="matrix-canvas"></canvas>
        <span id="console"></span><span class="cursor"></span>
    </div>

    <div id="control-panel">
        <select id="mode-select" class="f-yellow" onchange="changeMode(this.value)">
            <option value="hack">Chế độ: HACK MÃ</option>
            <option value="normal">Chế độ: THƯỜNG (GÕ CHỮ)</option>
        </select>
        
        <button onclick="openColorPicker()" class="f-blue">🎨 Bảng màu iOS</button>

        <select id="lang-select" onchange="changeLanguage()">
            <option value="vi">Tiếng Việt</option><option value="en">English</option>
            <option value="zh">中文</option><option value="ko">한국어</option><option value="ja">日本語</option>
        </select>

        <select id="speed-select" onchange="changeSpeed(this.value)">
            <option value="1">Tốc độ: 1x</option><option value="0.25">0.25x</option><option value="0.5">0.5x</option><option value="2">2x</option><option value="4">4x</option>
        </select>

        <button id="btn-auto" class="f-green" onclick="toggleAuto()">AUTO: OFF</button>
        <button onclick="toggleTheme()">Sáng / Tối</button>
        <button onclick="toggleFullscreen()">Toàn màn hình</button>
        <button class="f-red" onclick="clearConsole()">Xóa</button>
    </div>

    <div id="keyboard-container">
        <div class="key-row">
            <div class="key">1</div><div class="key">2</div><div class="key">3</div><div class="key">4</div><div class="key">5</div>
            <div class="key">6</div><div class="key">7</div><div class="key">8</div><div class="key">9</div><div class="key">0</div>
        </div>
        <div class="key-row">
            <div class="key" data-key="Q">Q</div><div class="key" data-key="W">W</div><div class="key" data-key="E">E</div><div class="key" data-key="R">R</div><div class="key" data-key="T">T</div>
            <div class="key" data-key="Y">Y</div><div class="key" data-key="U">U</div><div class="key" data-key="I">I</div><div class="key" data-key="O">O</div><div class="key" data-key="P">P</div>
        </div>
        <div class="key-row">
            <div class="key" data-key="A">A</div><div class="key" data-key="S">S</div><div class="key" data-key="D">D</div><div class="key" data-key="F">F</div><div class="key" data-key="G">G</div>
            <div class="key" data-key="H">H</div><div class="key" data-key="J">J</div><div class="key" data-key="K">K</div><div class="key" data-key="L">L</div><div class="key f-orange" onclick="triggerProgressEffect()">DECRYPT</div>
        </div>
        <div class="key-row">
            <div class="key f-purple" data-key="SHIFT">SHFT</div><div class="key" data-key="Z">Z</div><div class="key" data-key="X">X</div><div class="key" data-key="C">C</div><div class="key" data-key="V">V</div>
            <div class="key" data-key="B">B</div><div class="key" data-key="N">N</div><div class="key" data-key="M">M</div><div class="key f-red" data-key="BACKSPACE">BS</div>
        </div>
        <div class="key-row">
            <div class="key f-blue" style="flex: 2;" data-key="SPACE">SPACE</div>
            <div class="key f-green" style="flex: 1;" data-key="ENTER">ENTER</div>
        </div>
    </div>

    <div id="ios-color-picker">
        <div class="picker-header">
            <span>Màu sắc (Lưới)</span>
            <button class="close-btn" onclick="closeColorPicker()">✕</button>
        </div>
        <div class="color-grid" id="color-grid-box"></div>
    </div>

    <div id="progress-box" class="overlay-box">
        <div id="progress-title">⚡ DECRYPTING SYSTEM ⚡</div>
        <div class="progress-bar-bg"><div id="p-fill" class="progress-bar-fill"></div></div>
        <div id="p-status" style="margin-top: 8px; font-size: 12px;">STATUS: CONNECTING...</div>
    </div>

    <div id="success-box" class="overlay-box">
        <div>🔒 MAINFRAME OVERRIDE 🔒</div>
        <div style="font-size: 24px; margin: 10px 0;">ACCESS GRANTED</div>
        <div class="progress-bar-bg"><div id="s-fill" class="progress-bar-fill" style="width: 100%"></div></div>
        <div style="margin-top: 8px; font-size: 11px; color: #aaa;">DATA INJECTION COMPLETED 100%</div>
    </div>

    <script>
        const codeRepo = {
            vi: `// KHỞI TẠO TIẾN TRÌNH THÂM NHẬP...\n#include <stdio.h>\nvoid inject_core() {\n    printf("Đang nạp bộ nhớ đệm độc hại...\\n");\n    printf("Quyền ROOT khả dụng trên phân vùng 0x4F\\n");\n}`,
            en: `// INITIALIZING PENETRATION...\n#include <network.h>\nvoid inject_core() {\n    printf("Loading malicious buffer...\\n");\n    printf("ROOT Privilege obtained on sector 0x4F\\n");\n}`,
            zh: `// 初始化系统渗透进程...\n#include <stdio.h>\nvoid inject_core() {\n    printf("正在向堆栈加载恶意密匙...\\n");\n    printf("成功获取 ROOT 权限\\n");\n}`,
            ko: `// 시스템 침투 프로세스...\n#include <stdio.h>\nvoid inject_core() {\n    printf("스택에 악성 버퍼 로드 중...\\n");\n    printf("ROOT 권한 획득 성공\\n");\n}`,
            ja: `// システム侵入プロセス...\n#include <stdio.h>\nvoid inject_core() {\n    printf("悪意のあるバッファをロード中...\\n");\n    printf("ROOT 権限の取得に成功\\n");\n}`
        };

        let currentMode = 'hack'; // 'hack' hoặc 'normal'
        let currentLang = 'vi';
        let codeIndex = 0;
        let autoInterval = null;
        let speedMultiplier = 1;
        let isOverlayActive = false;

        const consoleElem = document.getElementById('console');
        const wrapper = document.getElementById('terminal-wrapper');

        // Tạo bảng màu lưới giống iPhone
        const iosColors = [
            '#ffffff','#e5e5ea','#d1d1d6','#c7c7cc','#aeaeb2','#8e8e93','#636366','#48484a','#3a3a3c','#2c2c2e','#1c1c1e','#000000',
            '#ff453a','#ff9f0a','#ffd60a','#30d158','#64d2ff','#0a84ff','#5e5ce6','#bf5af2','#ff375f','#ac8e68','#e4c79b','#bfac8d',
            '#ff3b30','#ff9500','#ffcc00','#34c759','#5ac8fa','#007aff','#5856d6','#af52de','#ff2d55','#a2845e','#d1b48c','#b5a07b',
            '#ff6b6b','#feca57','#1dd1a1','#48dbfb','#54a0ff','#5f27cd','#c8d6e5','#576574','#222f3e','#10ac84','#ee5253','#01a3a4'
        ];
        
        const gridBox = document.getElementById('color-grid-box');
        iosColors.forEach(color => {
            const cell = document.createElement('div');
            cell.className = 'color-cell';
            cell.style.backgroundColor = color;
            cell.onclick = () => {
                document.body.style.color = color;
                document.querySelector('.cursor').style.backgroundColor = color;
                closeColorPicker();
            };
            gridBox.appendChild(cell);
        });

        function openColorPicker() { document.getElementById('ios-color-picker').style.display = 'block'; }
        function closeColorPicker() { document.getElementById('ios-color-picker').style.display = 'none'; }
        function changeMode(val) { currentMode = val; clearConsole(); }

        // Xử lý logic gõ phím chính
        function handleInput(keyChar) {
            if (isOverlayActive) return;

            if (currentMode === 'hack') {
                // Chế độ hack: tự phun mã nguồn bất kể phím gì
                let currentCode = codeRepo[currentLang];
                let charsToPrint = Math.floor((Math.random() * 4 + 3) * speedMultiplier);

                for (let i = 0; i < charsToPrint; i++) {
                    if (codeIndex < currentCode.length) {
                        consoleElem.textContent += currentCode[codeIndex];
                        codeIndex++;
                    } else {
                        codeIndex = 0;
                        consoleElem.textContent += '\n\n/* --- BREAK IN SEQUENCE --- */\n\n';
                    }
                }
                if(Math.random() < 0.015) triggerProgressEffect();
            } else {
                // Chế độ thường: Đánh văn bản thực tế
                if (keyChar === 'BACKSPACE') {
                    consoleElem.textContent = consoleElem.textContent.slice(0, -1);
                } else if (keyChar === 'SPACE') {
                    consoleElem.textContent += ' ';
                } else if (keyChar === 'ENTER') {
                    consoleElem.textContent += '\n';
                } else if (keyChar === 'SHIFT' || keyChar === 'DECRYPT') {
                    // Phím chức năng không in chữ
                } else {
                    consoleElem.textContent += keyChar;
                }
            }
            wrapper.scrollTop = wrapper.scrollHeight;
        }

        // Hiệu ứng bẻ khóa loading %
        function triggerProgressEffect() {
            if (isOverlayActive) return;
            isOverlayActive = true;
            const box = document.getElementById('progress-box');
            const fill = document.getElementById('p-fill');
            const status = document.getElementById('p-status');
            box.style.display = 'block';
            
            let percent = 0;
            let statuses = ["CONNECTING NODE...", "BYPASSING FIREWALL...", "INJECTING SHELLCODE..."];
            let interval = setInterval(() => {
                percent += Math.floor(Math.random() * 10) + 5;
                if(percent > 100) percent = 100;
                fill.style.width = percent + '%';
                status.textContent = `${statuses[Math.floor(percent/40)] || statuses[2]} (${percent}%)`;
                
                if(percent >= 100) {
                    clearInterval(interval);
                    setTimeout(() => {
                        box.style.display = 'none';
                        isOverlayActive = false;
                        triggerSuccessEffect();
                    }, 400);
                }
            }, 800 * 0.1);
        }

        function triggerSuccessEffect() {
            isOverlayActive = true;
            const box = document.getElementById('success-box');
            box.style.display = 'block';
            setTimeout(() => { box.style.display = 'none'; isOverlayActive = false; }, 1800);
        }

        function toggleAuto() {
            const btn = document.getElementById('btn-auto');
            if (autoInterval) {
                clearInterval(autoInterval); autoInterval = null;
                btn.textContent = "AUTO: OFF";
            } else {
                currentMode = 'hack';
                document.getElementById('mode-select').value = 'hack';
                autoInterval = setInterval(() => handleInput('AUTO'), 60);
                btn.textContent = "AUTO: ON";
            }
        }

        function changeSpeed(val) { speedMultiplier = parseFloat(val); }
        function toggleTheme() { document.body.classList.toggle('light-mode'); }
        function changeLanguage() { currentLang = document.getElementById('lang-select').value; clearConsole(); }
        function clearConsole() { consoleElem.textContent = ""; codeIndex = 0; }
        function toggleFullscreen() {
            if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(e => {});
            else document.exitFullscreen();
        }

        // Gán sự kiện cho phím ảo di động
        document.querySelectorAll('.key').forEach(k => {
            const action = () => {
                const keyVal = k.getAttribute('data-key') || k.textContent;
                handleInput(keyVal);
            };
            k.addEventListener('touchstart', (e) => { e.preventDefault(); action(); }, {passive: false});
            k.addEventListener('mousedown', (e) => { e.preventDefault(); action(); });
        });

        // Gán sự kiện cho phím vật lý máy tính
        document.addEventListener('keydown', (e) => {
            if([32, 37, 38, 39, 40].indexOf(e.keyCode) > -1) e.preventDefault();
            let keyStr = e.key.toUpperCase();
            if(e.key === 'Backspace') keyStr = 'BACKSPACE';
            if(e.key === ' ') keyStr = 'SPACE';
            if(e.key === 'Enter') keyStr = 'ENTER';
            handleInput(keyStr);
        });

        // Hiệu ứng dòng mưa Ma trận (Matrix Rain) chạy ngầm siêu đẹp
        const canvas = document.getElementById('matrix-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const alphabet = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ☣☣⚡⚡";
        const fontSize = 14; const columns = canvas.width / fontSize;
        const rainDrops = Array(Math.floor(columns)).fill(1);

        function drawMatrix() {
            ctx.fillStyle = 'rgba(5, 5, 5, 0.05)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = document.body.style.color || '#30d158';
            ctx.font = fontSize + 'px monospace';
            for (let i = 0; i < rainDrops.length; i++) {
                const text = alphabet.charAt(Math.floor(Math.random() * alphabet.length));
                ctx.fillText(text, i * fontSize, rainDrops[i] * fontSize);
                if (rainDrops[i] * fontSize > canvas.height && Math.random() > 0.975) rainDrops[i] = 0;
                rainDrops[i]++;
            }
        }
        setInterval(drawMatrix, 30);

        consoleElem.textContent = "MAINFRAME INITIALIZED...\nCHOOSE MODE AND INTERACT.\n\n";
    </script>
</body>
</html>
